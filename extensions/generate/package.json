{
	"name": "generate",
	"description": "Please enter a description for your extension",
	"icon": "extension",
	"version": "1.0.0",
	"keywords": [
		"directus",
		"directus-extension",
		"directus-extension-endpoint"
	],
	"type": "module",
	"files": [
		"dist",
		"fonts"
	],
	"directus:extension": {
		"type": "endpoint",
		"path": "dist/index.js",
		"source": "src/index.ts",
		"host": "^10.10.0"
	},
	"scripts": {
		"build": "node ../deploy-extension.js generate",
		"dev": "directus-extension build -w --no-minify",
		"link": "directus-extension link",
		"validate": "directus-extension validate"
	},
	"devDependencies": {
		"@directus/extensions-sdk": "17.0.9",
		"@types/node": "^25.3.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"dotenv": "^16.3.1",
		"pdfmake": "^0.3.4"
	}
}
